NEXT_PUBLIC_HERMES_API_URL=https://your-hermes-backend.example.com
HERMES_API_URL=https://your-hermes-backend.example.com
HERMES_API_KEY=your-api-key-here

# Web Push (VAPID) — run `npm run vapid:generate` to create keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secret for Hermes backend / cron to call POST /api/push/send
PUSH_WEBHOOK_SECRET=
